{
  "name": "yummy",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "android": "yarn workspace @yummy/mobile android",
    "ios": "yarn workspace @yummy/mobile ios",
    "start": "yarn workspace @yummy/mobile start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "prettier": "2.8.8",
    "eslint": "^8.19.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.9.1"
}
